    "@types/eslint__js": "^8.42.3",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.7",
    "@types/node": "^20.14.11",
    "eslint": "^9.7.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "terser": "^5.31.3",
    "tsup": "^8.1.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^7.16.1"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.6.4",
    "chalk": "^5.3.0",
